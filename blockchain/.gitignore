!node1/keystore/
!node1/keystore/**

# Node 2: keep password + keystore, ignore everything else
node2/*
!node2/password.txt
!node2/keystore/
!node2/keystore/**

# Node 3: keep password + keystore, ignore everything else
node3/*
!node3/password.txt
!node3/keystore/
!node3/keystore/**

# Geth binary and installation files
geth-linux-amd64-*/
geth-darwin-amd64-*/
geth-windows-amd64-*/

